# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/
MANIFEST

# ── PyInstaller ──────────────────────────────────────────────────────────────
# Compiled output – regenerated by `pyinstaller build.spec` (already covered above)
# Keep hand-edited .spec files (e.g. build.spec), but ignore auto-generated ones
*.spec
!build.spec

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
*.lnk
$RECYCLE.BIN/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── QSettings / runtime config ───────────────────────────────────────────────
# Ignore auto-generated config files; keep manually committed ones if any
*.ini
*.cfg
macros/generate_drawing.catvba
macros/catia_companion.catvba
drawing_templates/
drawing_templates/EHANG_A3_V1.CATDrawing
macros/test.catvbs
macros/fastener_assembly.catvba
macros/nut_plate_assembly.catvba
crack/
macros/refresh_drawing_info.catvba
